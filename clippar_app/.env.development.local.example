# Dev environment for the "Clippar Dev" build (com.clippar.app.dev).
# Copy to .env.development.local and fill in with your DEV Supabase project's keys.
# Loaded by `expo start` when APP_VARIANT=development is set, e.g.:
#   APP_VARIANT=development npx expo start
#
# For EAS Build, these values come from EAS Secrets (@SUPABASE_URL_DEV, etc.)
# referenced in eas.json — this file is only used for local dev runs.

# Supabase (DEV project — create a separate Supabase project for testing)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_DEV_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_DEV_SERVICE_ROLE_KEY

# Stripe (test keys — same as prod test keys are fine if you only have one Stripe account)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Pipeline (point at a dev deploy or reuse prod — your choice)
EXPO_PUBLIC_PIPELINE_URL=https://clippar-pipeline-dev.onrender.com
EXPO_PUBLIC_PIPELINE_API_KEY=clippar-mobile-dev

# Concat
EXPO_PUBLIC_CONCAT_URL=https://clippar-concat-dev.onrender.com

# Golf Course API (same key works in both envs)
EXPO_PUBLIC_GOLF_COURSE_API_KEY=JL2HSOEKW7QQ6MH2ZYQUIZLNRM

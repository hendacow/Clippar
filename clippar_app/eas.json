{
  "cli": { "version": ">= 12.0.0", "appVersionSource": "remote" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "ios": {
        "simulator": false
      },
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "ios": { "simulator": false },
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "environment": "production",
      "ios": { "buildConfiguration": "Release" },
      "android": { "buildType": "app-bundle" },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "PLACEHOLDER_REPLACE_ME",
        "ascAppId": "PLACEHOLDER_REPLACE_ME",
        "appleTeamId": "PLACEHOLDER_REPLACE_ME"
      }
    }
  }
}
